{% extends 'convergine-contentbuddy/_layouts/_settings' %}
{% do view.registerAssetBundle("convergine\\contentbuddy\\assets\\BuddyAssets") %}
{% import '_includes/forms' as forms %}

{% set title = 'Settings' %}
{% set selectedSubnavItem = 'settings' %}

{% set fullPageForm = true %}

{% block content %}
    {{ craft.contentbuddy.checkLicense()|raw }}
    <input type="hidden" name="action" value="convergine-contentbuddy/settings/save-settings">
    {% namespace 'settings' %}
        {{ forms.selectField({
            label: 'AI Service'|t('convergine-contentbuddy'),
            name: 'textAi',
            value: settings.textAi,
            options: {
                "openai": "OpenAI",
                "xai": "xAI",
                "anthropic": "Anthropic",
                "openrouter": "OpenRouter"
            },
            toggle: true
        }) }}

        <div id="openai" class="{% if settings.textAi != 'openai' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'OpenAI Preferred Model'|t('convergine-contentbuddy'),
                name: 'preferredModel',
                value: settings.preferredModel,
                instructions: 'modelDescription'|t('convergine-contentbuddy'),
                options: [
                    { optgroup: "GPT Models" },



                    { value: "gpt-5.1", label: "gpt-5.1" },
                    { value: "gpt-5.1-mini", label: "gpt-5.1-mini" },
                    { value: "gpt-5-nano", label: "gpt-5-nano" },
                    { value: "gpt-5.1-codex", label: "gpt-5.1-codex" },
                    { value: "gpt-5.1-codex-mini", label: "gpt-5.1-codex-mini" },

                    { value: "gpt-4.1", label: "gpt-4.1" },
                    { value: "gpt-4.1-mini", label: "gpt-4.1-mini" },
                    { value: "gpt-4.1-nano", label: "gpt-4.1-nano" },

                    { value: "gpt-4.5-preview", label: "gpt-4.5-preview" },
                    { value: "gpt-4o", label: "gpt-4o" },
                    { value: "gpt-4o-mini", label: "gpt-4o-mini" },
                    { value: "gpt-4", label: "gpt-4" },
                    { value: "gpt-4-turbo", label: "gpt-4-turbo" },

                    { value: "gpt-3.5-turbo", label: "gpt-3.5-turbo" },

                    { optgroup: "Reasoning Models" },
                    { value: "o1", label: "o1" },
                    { value: "o3-mini", label: "o3-mini" }
                ]
            }) }}

            {{ forms.autosuggestField({
                label: 'API: Access Token'|t('convergine-contentbuddy'),
                name: 'apiToken',
                value: settings.apiToken,
                instructions: 'Access token for the ChatGPT API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>

        <div id="xai" class="{% if settings.textAi != 'xai' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'xAI Preferred Model'|t('convergine-contentbuddy'),
                name: 'xAiModel',
                value: settings.xAiModel,
                instructions: 'xAiModelDescription'|t('convergine-contentbuddy'),
                options: {
                    "grok-4.3": "grok-4.3",
                    "grok-4.5": "grok-4.5",
                    "grok-4.20-0309-reasoning": "grok-4.20-0309-reasoning",
                }
            }) }}

            {{ forms.selectField({
                label: 'xAI Reasoning Effort'|t('convergine-contentbuddy'),
                name: 'xAiReasoningEffort',
                value: settings.xAiReasoningEffort,
                instructions: 'xAiReasoningEffortDescription'|t('convergine-contentbuddy'),
                options: {
                    "none": "none",
                    "low": "low",
                    "medium": "medium",
                    "high": "high",
                }
            }) }}

            {{ forms.autosuggestField({
                label: 'xAI API Key'|t('convergine-contentbuddy'),
                name: 'xAiApiKey',
                value: settings.xAiApiKey,
                instructions: 'API Key for the xAI API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>
        <div id="anthropic" class="{% if settings.textAi != 'anthropic' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'Anthropic Preferred Model'|t('convergine-contentbuddy'),
                name: 'anthropicModel',
                value: settings.anthropicModel,
                instructions: 'anthropicModelDescription'|t('convergine-contentbuddy'),
                options: {
                    "claude-sonnet-4-5-20250929": "Claude Sonnet 4.5",
                    "claude-haiku-4-5-20251001": "Claude Haiku 4.5",
                    "claude-opus-4-5-20251101": "Claude Opus 4.5"
                }
            }) }}

            {{ forms.autosuggestField({
                label: 'Anthropic API Key'|t('convergine-contentbuddy'),
                name: 'anthropicApiKey',
                value: settings.anthropicApiKey,
                instructions: 'API Key for the Anthropic API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>

        <div id="openrouter" class="{% if settings.textAi != 'openrouter' %}hidden{% endif %}">
            {% if settings.openrouterApiKey !='' %}
                {{ forms.selectField({
                    label: 'OpenRouter Preferred Model'|t('convergine-contentbuddy'),
                    name: 'openrouterModel',
                    value: settings.openrouterModel,
                    instructions: 'openRouterModelDescription'|t('convergine-contentbuddy'),
                    options: openRouteModels
                }) }}
            {% else %}
                <p class="warning">{{ 'openRouterSaveKeyDescription'|t('convergine-contentbuddy') }}</p>
            {% endif %}

            {{ forms.autosuggestField({
                label: 'OpenRouter API Key'|t('convergine-contentbuddy'),
                name: 'openrouterApiKey',
                value: settings.openrouterApiKey,
                instructions: 'API Key for the OpenRouter API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>

        {{ forms.textareaField({
            label: 'System Message'|t('convergine-contentbuddy'),
            name: 'systemMessage',
            value: settings.systemMessage,
            instructions: 'systemMessageDescription'|t('convergine-contentbuddy')
        }) }}

        <div class="buddy-slider-cont field">
            <div class="heading">
                <label>{{ 'Temperature'|t('convergine-contentbuddy') }}</label>
            </div>
            <div class="flex">{{ 'Sampling temperature to use, between 0 and 2. Higher values like 0.8 will make the output more random, while lower values like 0.2 will make it more focused and deterministic'|t('convergine-contentbuddy')}}</div>
            <div class="flex">
                <input
                        type="range"
                        step="0.1"
                        min="0"
                        max="2"
                        class="buddy-slider"
                        id="temperature"
                        value="{{ settings.temperature }}"
                        name="temperature"
                        data-gtm-form-interact-field-id="0"
                >
                <span>{{ settings.temperature }}</span>
            </div>
        </div>

    {% endnamespace %}
{% endblock %}
