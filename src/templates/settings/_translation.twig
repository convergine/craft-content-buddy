{% extends 'convergine-contentbuddy/_layouts/_settings' %}
{% do view.registerAssetBundle("convergine\\contentbuddy\\assets\\BuddyAssets") %}
{% import '_includes/forms' as forms %}

{% set title = 'Settings' %}
{% set selectedSubnavItem = 'settings' %}

{% set fullPageForm = true %}

{% block content %}
    {{ craft.contentbuddy.checkLicense()|raw }}
    <input type="hidden" name="action" value="convergine-contentbuddy/settings/save-settings">
    {% namespace 'settings' %}
        {{ forms.selectField({
            label: 'AI Service'|t('convergine-contentbuddy'),
            name: 'translationAi',
            value: settings.translationAi,
            options: {
                "openai": "OpenAI",
                "xai": "xAI",
                "deepl": "DeepL",
                "anthropic": "Anthropic",
                "openrouter": "OpenRouter"
            },
            toggle: true
        }) }}

        <div id="openai" class="{% if settings.translationAi != 'openai' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'OpenAI Preferred Model'|t('convergine-contentbuddy'),
                name: 'preferredTranslationModel',
                value: settings.preferredTranslationModel,
                instructions: 'modelDescription'|t('convergine-contentbuddy'),
                options: [
                    { optgroup: "GPT Models" },

                    { value: "gpt-5.1", label: "gpt-5.1" },
                    { value: "gpt-5.1-mini", label: "gpt-5.1-mini" },
                    { value: "gpt-5-nano", label: "gpt-5-nano" },

                    { value: "gpt-4.5-preview", label: "gpt-4.5-preview" },
                    { value: "gpt-4o", label: "gpt-4o" },
                    { value: "gpt-4o-mini", label: "gpt-4o-mini" },
                    { value: "gpt-4-turbo", label: "gpt-4-turbo" },
                    { value: "gpt-4", label: "gpt-4" },
                    { value: "gpt-3.5-turbo", label: "gpt-3.5-turbo" },

                    { optgroup: "Reasoning Models" },
                    { value: "o1", label: "o1" },
                    { value: "o3-mini", label: "o3-mini" }
                ]
            }) }}
            <div id="assistantsContainer" style="display:{% if 'gpt-4' in settings.preferredTranslationModel %}block{% else %}none{% endif %}">
                {% if settings.apiToken %}
                    {{ forms.selectField({
                        label: 'OpenAI Assistant'|t('convergine-contentbuddy'),
                        name: 'openAiAssistantId',
                        value: settings.openAiAssistantId,
                        instructions: 'assistantDescription'|t('convergine-contentbuddy'),
                        options: assistants
                    }) }}
                {% else %}
                <div  class="field" >
                    <div class="heading">
                        <label >{{ 'OpenAI Assistant'|t('convergine-contentbuddy') }}</label>
                    </div>
                    <div class="instructions">
                        <p>{{ 'Before select Assistant, need save access token.'|t('convergine-contentbuddy') }}</p>
                    </div>
                </div>
                {% endif %}
            </div>

            {{ forms.autosuggestField({
                label: 'API: Access Token'|t('convergine-contentbuddy'),
                name: 'apiToken',
                value: settings.apiToken,
                instructions: 'Access token for the ChatGPT API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>

        <div id="xai" class="{% if settings.translationAi != 'xai' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'xAI Preferred Model'|t('convergine-contentbuddy'),
                name: 'xAiModel',
                value: settings.xAiModel,
                instructions: 'xAiModelDescription'|t('convergine-contentbuddy'),
                options: {
                    "grok-4.3": "grok-4.3",
                    "grok-4.5": "grok-4.5",
                    "grok-4.20-0309-reasoning": "grok-4.20-0309-reasoning",
                }
            }) }}

            {{ forms.selectField({
                label: 'xAI Reasoning Effort'|t('convergine-contentbuddy'),
                name: 'xAiReasoningEffort',
                value: settings.xAiReasoningEffort,
                instructions: 'xAiReasoningEffortDescription'|t('convergine-contentbuddy'),
                options: {
                    "none": "none",
                    "low": "low",
                    "medium": "medium",
                    "high": "high",
                }
            }) }}

            {{ forms.autosuggestField({
                label: 'xAI API Key'|t('convergine-contentbuddy'),
                name: 'xAiApiKey',
                value: settings.xAiApiKey,
                instructions: 'API Key for the xAI API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>

        <div id="deepl" class="{% if settings.translationAi != 'deepl' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'DeepL API Version'|t('convergine-contentbuddy'),
                name: 'deepLApiVersion',
                value: settings.deepLApiVersion,
                instructions: 'deepLApiVersionDescription'|t('convergine-contentbuddy'),
                options: {
                    "v2": "v2",
                    "v1": "v1",
                }
            }) }}

            {{ forms.autosuggestField({
                label: 'DeepL API Key'|t('convergine-contentbuddy'),
                name: 'deepLApiKey',
                value: settings.deepLApiKey,
                instructions: 'API Key for the DeepL API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}

            {% set glossaryOptions = {
                '': 'None'
            } %}

            {% if settings.deepLGlossaryId is not empty %}
                {% set glossaryOptions = glossaryOptions|merge({
                    (settings.deepLGlossaryId): settings.deepLGlossaryId
                }) %}
            {% endif %}

            <div id="deepLGlossaryField" style="display: none;">
                {{ forms.selectField({
                    label: 'DeepL Glossary'|t('convergine-contentbuddy'),
                    name: 'deepLGlossaryId',
                    value: settings.deepLGlossaryId,
                    instructions: 'deepLGlossaryIdDescription'|t('convergine-contentbuddy'),
                    options: glossaryOptions
                }) }}
            </div>
        </div>
        <div id="anthropic" class="{% if settings.translationAi != 'anthropic' %}hidden{% endif %}">
            {{ forms.selectField({
                label: 'Anthropic Preferred Model'|t('convergine-contentbuddy'),
                name: 'anthropicTranslationModel',
                value: settings.anthropicTranslationModel,
                instructions: 'anthropicModelDescription'|t('convergine-contentbuddy'),
                options: {
                    "claude-sonnet-4-5-20250929": "Claude Sonnet 4.5",
                    "claude-haiku-4-5-20251001": "Claude Haiku 4.5",
                    "claude-opus-4-5-20251101": "Claude Opus 4.5"
                }
            }) }}

            {{ forms.autosuggestField({
                label: 'Anthropic API Key'|t('convergine-contentbuddy'),
                name: 'anthropicApiKey',
                value: settings.anthropicApiKey,
                instructions: 'API Key for the Anthropic API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>
        <div id="openrouter" class="{% if settings.textAi != 'openrouter' %}hidden{% endif %}">
            {% if settings.openrouterApiKey !='' %}
                {{ forms.selectField({
                    label: 'OpenRouter Preferred Model'|t('convergine-contentbuddy'),
                    name: 'openrouterTranslationModel',
                    value: settings.openrouterTranslationModel,
                    instructions: 'openRouterModelDescription'|t('convergine-contentbuddy'),
                    options: openRouteModels
                }) }}
            {% else %}
                <p class="warning">{{ 'openRouterSaveKeyDescription'|t('convergine-contentbuddy') }}</p>
            {% endif %}

            {{ forms.autosuggestField({
                label: 'Anthropic API Key'|t('convergine-contentbuddy'),
                name: 'openrouterApiKey',
                value: settings.openrouterApiKey,
                instructions: 'API Key for the OpenRouter API'|t('convergine-contentbuddy'),
                suggestEnvVars: true,
            }) }}
        </div>
        {{ forms.lightswitchField({
            label: 'Translate Slugs'|t('convergine-contentbuddy'),
            name: 'translateSlugs',
            instructions: 'If enabled, entry slugs will also be translated.'|t('convergine-contentbuddy'),
            on: settings.translateSlugs is defined and settings.translateSlugs == '1'
        }) }}

    {% endnamespace %}
{% endblock %}
{% js %}
window.onload  = function (){
    const modelSelectValue = document.querySelector('[name="settings[preferredTranslationModel]"]');
    const assistantContainer = document.getElementById('settings-assistantsContainer');
    modelSelectValue.addEventListener('change', e=>{
        const selValue = e.currentTarget.value;
        if(selValue.includes('gpt-4')){
            assistantContainer.style.display = 'block'
        }else{
            assistantContainer.style.display = 'none'
        }
    })
}
{% endjs %}